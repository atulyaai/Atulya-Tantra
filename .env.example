# Atulya Tantra — NP-DNA configuration
# Copy to .env and customize

# Model scaling (auto-scales if not set)
ATULYA_CONFIG=seed
ATULYA_DEVICE=cpu

# Training
ATULYA_TRAIN_STEPS=50
ATULYA_BATCH_SIZE=4
ATULYA_LR=2e-3
ATULYA_LOG_EVERY=10
ATULYA_CHECKPOINT_EVERY=25

# Host & Port Configuration (Set host to 0.0.0.0 for mobile/local network access)
ATULYA_HOST=127.0.0.1
ATULYA_PORT=8501

# Paths
ATULYA_OUTPUT_DIR=outputs
ATULYA_DATA_DIR=assets
ATULYA_BACKEND_PYTHON=
ATULYA_TRAIN_PYTHON=
ATULYA_DASHBOARD_MAX_STEPS=50000
ATULYA_MAX_DATASET_UPLOAD_GB=5

# Integrations
# Never commit real tokens here. Put live values only in local .env.
ATULYA_TELEGRAM_BOT_TOKEN=
ATULYA_TELEGRAM_CHAT_ID=
ATULYA_TELEGRAM_ALLOWLIST=
ATULYA_TELEGRAM_ALLOW_SEND=0

# Free-first brain provider chain
# 1. Ollama local provider (free/offline)
ATULYA_OLLAMA_MODEL=llama3
ATULYA_OLLAMA_HOST=http://localhost:11434
# 2. Native Tantra local model (free/local research model)
# 3. Groq free developer tier when configured
GROQ_API_KEY=
ATULYA_GROQ_MODEL=llama-3.3-70b-versatile
# 4. OpenRouter free models when configured
OPENROUTER_API_KEY=
ATULYA_OPENROUTER_MODEL=google/gemini-2.5-flash
# 5. Gemini free tier when configured
GEMINI_API_KEY=
ATULYA_GEMINI_MODEL=gemini-1.5-flash
# 6. OpenAI optional paid fallback only
OPENAI_API_KEY=
ATULYA_OPENAI_MODEL=gpt-4o-mini
# 7. NVIDIA NIM optional fallback
NVIDIA_API_KEY=
# NIM_API_KEY is also accepted as fallback
ATULYA_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# 8. OpenCode Zen fallback (offline persona-based response, no key required)

# Security & Session Authentication
ATULYA_DASHBOARD_TOKEN=your_secure_auth_token_here

# Debug
ATULYA_DEBUG=0
