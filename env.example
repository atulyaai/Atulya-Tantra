# Atulya Tantra - Environment Configuration
# Version: 2.5.0

# Application Settings
APP_NAME=Atulya Tantra
APP_VERSION=2.5.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atulya_tantra
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Configuration
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.7

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Feature Flags
ENABLE_STREAMING=true
ENABLE_VOICE_INTERFACE=true
ENABLE_VISION_PROCESSING=true
ENABLE_MULTIMODAL=true
ENABLE_AUTONOMOUS_OPERATIONS=false
ENABLE_DESKTOP_AUTOMATION=false
ENABLE_EXTERNAL_INTEGRATIONS=false

# JARVIS Features
ENABLE_PERSONALITY_ENGINE=true
ENABLE_EMOTIONAL_INTELLIGENCE=true
ENABLE_PROACTIVE_ASSISTANCE=true
ENABLE_NATURAL_LANGUAGE_UNDERSTANDING=true

# Skynet Features
ENABLE_TASK_SCHEDULING=true
ENABLE_SELF_MONITORING=true
ENABLE_AUTO_HEALING=true
ENABLE_DECISION_ENGINE=true
ENABLE_MULTI_AGENT_COORDINATION=true

# Specialized Agents
ENABLE_CODE_AGENT=true
ENABLE_RESEARCH_AGENT=true
ENABLE_CREATIVE_AGENT=true
ENABLE_DATA_AGENT=true

# External Integrations
ENABLE_CALENDAR_INTEGRATION=false
ENABLE_EMAIL_INTEGRATION=false
ENABLE_STORAGE_INTEGRATION=false

# Calendar Integration
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Email Integration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
USE_TLS=true
USE_SSL=true

# Storage Integration
STORAGE_TYPE=local
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
DROPBOX_ACCESS_TOKEN=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# Monitoring Configuration
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ELK_STACK_ENABLED=false

# Performance Configuration
MAX_CONCURRENT_TASKS=10
MAX_RETRIES=3
RETRY_DELAY=60
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=20

# File Upload Configuration
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,gif,mp3,wav,mp4

# Voice Interface Configuration
WAKE_WORD=jarvis
VOICE_TIMEOUT=30
VOICE_LANGUAGE=en-US
TTS_VOICE=default

# System Configuration
SYSTEM_MONITORING_INTERVAL=60
HEALTH_CHECK_INTERVAL=30
AUTO_BACKUP_ENABLED=false
BACKUP_INTERVAL=24

# Development Configuration
RELOAD=true
WORKERS=1
HOST=0.0.0.0
PORT=8000

# Production Configuration (uncomment for production)
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# WORKERS=4
# RELOAD=false
