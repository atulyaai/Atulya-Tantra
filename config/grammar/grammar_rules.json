{
  "rules": [
    {
      "name": "en_double_space",
      "language": "en",
      "pattern": "  +",
      "replacement": " ",
      "description": "Remove double spaces",
      "enabled": true
    },
    {
      "name": "en_capital_i",
      "language": "en",
      "pattern": "\\bi\\b",
      "replacement": "I",
      "description": "Capitalize pronoun I",
      "enabled": true
    },
    {
      "name": "en_period_space",
      "language": "en",
      "pattern": "\\.(?=[^\\s.])",
      "replacement": ". ",
      "description": "Ensure space after period \u2014 not at line end",
      "enabled": true
    },
    {
      "name": "en_comma_space",
      "language": "en",
      "pattern": ",\\s*",
      "replacement": ", ",
      "description": "Ensure space after comma",
      "enabled": true
    },
    {
      "name": "en_apostrophe",
      "language": "en",
      "pattern": "(\\w)'(\\w)",
      "replacement": "\\1'\\2",
      "description": "Fix apostrophe spacing",
      "enabled": true
    },
    {
      "name": "hi_half_consonant",
      "language": "hi",
      "pattern": "([\\u0900-\\u097F])\\s+([\\u0900-\\u097F])",
      "replacement": "\\1\\2",
      "description": "Join half consonants",
      "enabled": true
    },
    {
      "name": "hi_vowel_sign",
      "language": "hi",
      "pattern": "([\\u0905-\\u0914])\\s+([\\u093E-\\u094F])",
      "replacement": "\\1\\2",
      "description": "Join vowel signs",
      "enabled": true
    },
    {
      "name": "sa_sandhi",
      "language": "sa",
      "pattern": "([\\u0900-\\u097F])\\s+([\\u0900-\\u097F])",
      "replacement": "\\1\\2",
      "description": "Apply sandhi rules",
      "enabled": true
    },
    {
      "name": "sa_virama",
      "language": "sa",
      "pattern": "([\\u0900-\\u097F])\\s+([\\u094D])",
      "replacement": "\\1\\2",
      "description": "Apply virama",
      "enabled": true
    },
    {
